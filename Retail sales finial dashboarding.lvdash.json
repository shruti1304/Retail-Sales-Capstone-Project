            "displayName": "Date"
          },
          {
            "name": "store_id",
            "expr": "source.store_id",
            "displayName": "Store Id"
          },
          {
            "name": "product_id",
            "expr": "source.product_id",
            "displayName": "Product Id"
          },
          {
            "name": "price",
