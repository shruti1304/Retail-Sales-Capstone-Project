            "displayName": "Price"
          },
          {
            "name": "is_promoted",
            "expr": "source.is_promoted",
            "displayName": "Is Promoted"
          },
          {
            "name": "actual_sales",
            "expr": "source.actual_sales",
            "displayName": "Actual Sales"
          },
          {
            "name": "forecasted_demand",
            "expr": "source.forecasted_demand",
            "displayName": "Forecasted Demand"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    }
  ],
